# ============================================
# PayPulse Backend — Environment Variables
# ============================================

# Required
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/paypulse
JWT_SECRET=your-secret-key-here
PORT=5002

# ============================================
# Stripe — LIVE vs TEST is controlled purely by the key prefix.
# Set sk_live_... in production, sk_test_... in staging/dev.
# Price IDs must match the mode (test IDs only work with test keys).
# ============================================
STRIPE_SECRET_KEY=sk_test_or_sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Live price IDs from your Stripe live dashboard (required in production).
# Fallbacks in routes/stripe.js are test-mode IDs and will 500 on live keys.
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# For cron job authentication (api/cron/payday.js)
CRON_SECRET=a-random-string

# App URLs (used in verification emails and reminders)
APP_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5173/app

# Email (SMTP) — for bill reminders and verification
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Use an App Password, not your regular Gmail password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@paypulse.app

# ============================================
# PayPulse Frontend — Environment Variables
# (set in Vercel dashboard for the frontend project)
# ============================================
# VITE_API_URL=https://your-backend.vercel.app
