# ============================================
# PayPulse Backend — Environment Variables
# ============================================

# Required
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/paypulse
JWT_SECRET=your-secret-key-here
PORT=5002

# ============================================
# Stripe — LIVE vs TEST is controlled purely by the key prefix.
# Set the live key in production env (Vercel) only — never paste it
# into this file. Local development should always use the test key.
# Price IDs must match the mode (test IDs only work with test keys).
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe dashboard for the corresponding mode (test
# or live). Required — no fallback. Live keys reject test price IDs and
# vice versa, so these MUST match STRIPE_SECRET_KEY's mode.
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# One-time data migrations (auto-verify legacy users, zero out legacy
# totalSavings). Set to "true", deploy once, verify in logs, then unset
# and redeploy. Leaving this on adds linear-in-user-count cold-start
# latency on Vercel. See README "Deployment notes".
ONE_TIME_MIGRATION_ENABLED=

# App URLs (used in verification emails and reminders)
APP_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5173/app

# CORS allowlist — comma-separated list of origins that may call the API.
# When unset, the backend falls back to APP_URL + the default frontend
# domain + localhost dev hosts + paypulse-*.vercel.app preview deploys.
# Set this once you have a custom production domain.
ALLOWED_ORIGINS=https://paypulse.money,https://paypulse-frontend.vercel.app,http://localhost:5173

# Email — PayPulse uses Gmail SMTP via nodemailer. Set EMAIL_USER to the
# authenticated Gmail account and EMAIL_PASS to a Gmail App Password (NOT
# your regular account password). Leave both blank in local dev to skip
# outbound email entirely.
EMAIL_USER=
EMAIL_PASS=
# Optional: override the default "from" address. Gmail rewrites the domain
# to match the authenticated account unless the alias is configured in
# Google Workspace, so only set this when using a transactional provider.
EMAIL_FROM=

# ============================================
# PayPulse Frontend — Environment Variables
# (set in Vercel dashboard for the frontend project)
# ============================================
# VITE_API_URL=https://your-backend.vercel.app
