# Required
MONGO_URI=mongodb://localhost:27017/budget-app
JWT_SECRET=your-secret-key-here
PORT=5001

# App URL (used in verification emails)
APP_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5173/app

# Email (SMTP) configuration for bill reminders and verification
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Use an App Password, not your regular Gmail password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@paypulse.app
